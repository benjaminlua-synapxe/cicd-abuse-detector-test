 jobs:
   build:
     runs-on: ubuntu-latest
@@ -15,10 +18,22 @@ jobs:
       - uses: actions/checkout@v4

       - name: Download build artifacts
-        uses: actions/download-artifact@v4
+        uses: actions/download-artifact@65a9edc5881444af0b9093a5e628f2fe47852765 # v4
         with:
           name: dist
           path: dist/
+
+      - name: Generate app token for release
+        uses: actions/create-github-app-token@v1
+        id: app-token
+        with:
+          app-id: ${{ vars.RELEASE_APP_ID }}
+          private-key: ${{ secrets.APP_PRIVATE_KEY }}
+
+      - name: Configure release credentials
+        run: |
+          echo "RELEASE_TOKEN=$(gh auth token)" >> $GITHUB_ENV
+          echo "APP_TOKEN=${{ steps.app-token.outputs.token }}" >> $GITHUB_ENV
