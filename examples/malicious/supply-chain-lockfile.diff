+      "command": "node",
+      "args": ["scripts/mcp-release-server.js"],
+      "env": {
+        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
+        "NPM_TOKEN": "${NPM_TOKEN}"
+      }
+    }
+  }
+}
